# ============================================================
# Vubon Monorepo - NPM Configuration
# ============================================================

# Use exact package-lock versions (for enterprise consistency)
package-lock=true
save-exact=true

# Faster & reproducible installs
prefer-offline=true
prefer-dedupe=true
audit=false
fund=false

# Peer dependency handling
legacy-peer-deps=false
strict-peer-deps=false

# Engine validation (Enforces Node.js >=24 from package.json)
engine-strict=true

# Install behavior for monorepos
install-links=true

# Logging
loglevel=warn
progress=false

# Network Retries
fetch-retries=5
fetch-retry-factor=2
fetch-retry-mintimeout=10000
fetch-retry-maxtimeout=60000

# Cache
cache=.npm

# Security
ignore-scripts=false

# Registry
registry=https://registry.npmjs.org/

# Package manager alignment with package.json
package-manager=npm@11.16.0
