# ============================================================
# Vubon Monorepo - NPM Configuration
# ============================================================

# Use exact package-lock versions
package-lock=true
save-exact=true

# Faster & reproducible installs
prefer-offline=true
prefer-dedupe=true
audit=false
fund=false

# Peer dependency handling
legacy-peer-deps=false
strict-peer-deps=false

# Engine validation
engine-strict=true

# Install behavior
install-links=true

# Logging
loglevel=warn
progress=false

# Network
fetch-retries=5
fetch-retry-factor=2
fetch-retry-mintimeout=10000
fetch-retry-maxtimeout=60000

# Cache
cache=.npm

# Security
ignore-scripts=false

# Registry
registry=https://registry.npmjs.org/

# Package manager
package-manager=npm@10
