# ==============================================================================
# Vubon.com.bd - Enterprise Monorepo Git Ignore Config
# ==============================================================================

# ------------------------------------------------------------------------------
# Dependencies (কখনোই গিটে যাবে না)
# ------------------------------------------------------------------------------
node_modules/
.pnpm-store/

# ------------------------------------------------------------------------------
# Environment & Secrets (১০০% সিকিউরিটি লক - খুব জরুরি)
# ------------------------------------------------------------------------------
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
*.env
*.env.local

# .env.example ফাইলটি গিটে আপলোড হওয়া দরকার, তাই একে ফোর্স-এলাও করা হলো
!.env.example

# ------------------------------------------------------------------------------
# Build Outputs & Cache
# ------------------------------------------------------------------------------
dist/
build/
out/
.next/
.turbo/
.cache/
.npm/
.eslintcache
.prettiercache
*.tsbuildinfo

# ------------------------------------------------------------------------------
# Logs & System Files
# ------------------------------------------------------------------------------
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
.DS_Store
Thumbs.db
desktop.ini

# ------------------------------------------------------------------------------
# Prisma Database Configs
# ------------------------------------------------------------------------------
# লোকাল ডেভেলপমেন্ট মাইগ্রেশন লক বা টেস্ট ডাটাবেজ গিটে না পাঠানোই শ্রেয়
*.db
*.db-journal
# প্রিজমার জেনারেটেড ক্লায়েন্ট এবং মাইগ্রেশন ডাটা যদি লোকাল হয়
**/prisma/migrations-local/

# ------------------------------------------------------------------------------
# IDE / Editors Custom Settings
# ------------------------------------------------------------------------------
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json
!.vscode/launch.json
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# ------------------------------------------------------------------------------
# Testing & Coverage outputs
# ------------------------------------------------------------------------------
coverage/
.nyc_output/

# ------------------------------------------------------------------------------
# Temporary Files
# ------------------------------------------------------------------------------
tmp/
temp/
