# ==============================================================================
# Vubon Monorepo - Template Environment Variables
# Copy this file to '.env' and fill in your local secrets.
# ==============================================================================

# App Environment
NODE_ENV=development
PORT=5000

# Database - Prisma / PostgreSQL Connection
DATABASE_URL="postgresql://username:password@localhost:5432/database_name?schema=public"

# Authentication / JWT Secrets
JWT_ACCESS_SECRET="your-32-character-or-longer-secret"
JWT_REFRESH_SECRET="your-32-character-or-longer-secret"
JWT_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="7d"

# Third-Party / External Services
# SENDGRID_API_KEY=""
# STRIPE_SECRET_KEY=""
