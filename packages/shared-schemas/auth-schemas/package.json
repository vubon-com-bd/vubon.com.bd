{
  "name": "@vubon/shared-schemas",
  "version": "1.0.0",
  "description": "Single Source of Truth validation layer for vubon.com.bd ecommerce ecosystem - Bangladesh's #1 Enterprise E-commerce",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    },
    "./auth": {
      "types": "./dist/auth/index.d.ts",
      "import": "./dist/auth/index.mjs",
      "require": "./dist/auth/index.js"
    },
    "./role": {
      "types": "./dist/role/index.d.ts",
      "import": "./dist/role/index.mjs",
      "require": "./dist/role/index.js"
    },
    "./session": {
      "types": "./dist/session/index.d.ts",
      "import": "./dist/session/index.mjs",
      "require": "./dist/session/index.js"
    },
    "./user": {
      "types": "./dist/auth/user.schema.d.ts",
      "import": "./dist/auth/user.schema.mjs",
      "require": "./dist/auth/user.schema.js"
    },
    "./login": {
      "types": "./dist/auth/login.schema.d.ts",
      "import": "./dist/auth/login.schema.mjs",
      "require": "./dist/auth/login.schema.js"
    },
    "./register": {
      "types": "./dist/auth/register.schema.d.ts",
      "import": "./dist/auth/register.schema.mjs",
      "require": "./dist/auth/register.schema.js"
    },
    "./mfa": {
      "types": "./dist/auth/mfa.schema.d.ts",
      "import": "./dist/auth/mfa.schema.mjs",
      "require": "./dist/auth/mfa.schema.js"
    },
    "./verification": {
      "types": "./dist/auth/verification.schema.d.ts",
      "import": "./dist/auth/verification.schema.mjs",
      "require": "./dist/auth/verification.schema.js"
    },
    "./password-reset": {
      "types": "./dist/auth/password-reset.schema.d.ts",
      "import": "./dist/auth/password-reset.schema.mjs",
      "require": "./dist/auth/password-reset.schema.js"
    },
    "./social": {
      "types": "./dist/auth/social.schema.d.ts",
      "import": "./dist/auth/social.schema.mjs",
      "require": "./dist/auth/social.schema.js"
    },
    "./role-schema": {
      "types": "./dist/role/role.schema.d.ts",
      "import": "./dist/role/role.schema.mjs",
      "require": "./dist/role/role.schema.js"
    },
    "./permission": {
      "types": "./dist/role/permission.schema.d.ts",
      "import": "./dist/role/permission.schema.mjs",
      "require": "./dist/role/permission.schema.js"
    },
    "./session-schema": {
      "types": "./dist/session/session.schema.d.ts",
      "import": "./dist/session/session.schema.mjs",
      "require": "./dist/session/session.schema.js"
    },
    "./device": {
      "types": "./dist/session/device.schema.d.ts",
      "import": "./dist/session/device.schema.mjs",
      "require": "./dist/session/device.schema.js"
    }
  },
  "files": [
    "dist/**/*",
    "README.md"
  ],
  "scripts": {
    "build": "tsup",
    "build:tsc": "tsc",
    "clean": "rm -rf dist",
    "dev": "tsup --watch",
    "prepublishOnly": "npm run clean && npm run build",
    "type-check": "tsc --noEmit",
    "lint": "eslint src/**/*.ts",
    "lint:fix": "eslint src/**/*.ts --fix",
    "format": "prettier --write \"src/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\"",
    "test": "echo \"No tests yet\""
  },
  "keywords": [
    "validation",
    "zod",
    "schemas",
    "enterprise",
    "ecommerce",
    "vubon",
    "bangladesh",
    "auth",
    "rbac",
    "mfa",
    "session",
    "device",
    "bkash",
    "nagad",
    "rocket",
    "sslcommerz",
    "typescript"
  ],
  "author": "Vubon E-commerce",
  "license": "UNLICENSED",
  "private": true,
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  },
  "dependencies": {
    "zod": "^3.22.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@typescript-eslint/eslint-plugin": "^6.0.0",
    "@typescript-eslint/parser": "^6.0.0",
    "@vubon/shared-constants": "^1.0.0",
    "@vubon/shared-types": "^1.0.0",
    "eslint": "^8.0.0",
    "prettier": "^3.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.0.0",
    "vitest": "^1.0.0"
  },
  "peerDependencies": {
    "@vubon/shared-constants": "^1.0.0",
    "@vubon/shared-types": "^1.0.0",
    "zod": "^3.22.0"
  },
  "sideEffects": false,
  "publishConfig": {
    "access": "restricted",
    "registry": "https://npm.pkg.github.com/"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/vubon/shared-schemas.git"
  },
  "bugs": {
    "url": "https://github.com/vubon/shared-schemas/issues"
  },
  "homepage": "https://vubon.com.bd"
}
