      "require": "./dist/crypto/index.js"
    },
    "./validation": {
      "types": "./dist/validation/index.d.ts",
      "import": "./dist/validation/index.mjs",
      "require": "./dist/validation/index.js"
    },
    "./formatter": {
      "types": "./dist/formatter/index.d.ts",
      "import": "./dist/formatter/index.mjs",
      "require": "./dist/formatter/index.js"
    },
    "./device": {
      "types": "./dist/device/index.d.ts",
      "import": "./dist/device/index.mjs",
      "require": "./dist/device/index.js"
    },
    "./async": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    },
    "./env": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    },
