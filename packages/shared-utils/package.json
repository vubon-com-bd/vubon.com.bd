  "scripts": {
    "build": "tsup",
    "clean": "rm -rf dist",
    "dev": "tsup --watch",
    "type-check": "tsc --noEmit"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "date-fns": "^3.0.0",
    "jose": "^5.0.0",
    "libphonenumber-js": "^1.10.0",
    "ua-parser-js": "^1.0.0",
    "validator": "^13.11.0"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^20.0.0",
    "@types/ua-parser-js": "^0.7.39",
    "@types/validator": "^13.11.0",
    "tsup": "^8.5.1",
    "typescript": "^5.0.0"
  },
  "peerDependencies": {
    "@vubon/shared-constants": "file:../shared-constants",
    "@vubon/shared-types": "file:../shared-types",
    "@vubon/shared-schemas": "file:../shared-schemas"
  }
}
