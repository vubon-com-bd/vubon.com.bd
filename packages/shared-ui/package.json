{
  "name": "@vubon/shared-ui",
  "version": "1.0.0",
  "description": "Enterprise shared UI component library for vubon.com.bd ecommerce ecosystem - Bangladesh's #1 E-commerce",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    },
    "./components": {
      "types": "./dist/components/index.d.ts",
      "import": "./dist/components/index.mjs",
      "require": "./dist/components/index.js"
    },
    "./components/ui": {
      "types": "./dist/components/ui/index.d.ts",
      "import": "./dist/components/ui/index.mjs",
      "require": "./dist/components/ui/index.js"
    },
    "./components/forms": {
      "types": "./dist/components/forms/index.d.ts",
      "import": "./dist/components/forms/index.mjs",
      "require": "./dist/components/forms/index.js"
    },
    "./components/layout": {
      "types": "./dist/components/layout/index.d.ts",
      "import": "./dist/components/layout/index.mjs",
      "require": "./dist/components/layout/index.js"
    },
    "./hooks": {
      "types": "./dist/hooks/index.d.ts",
      "import": "./dist/hooks/index.mjs",
      "require": "./dist/hooks/index.js"
    },
    "./styles": {
      "types": "./dist/styles/index.d.ts",
      "import": "./dist/styles/index.mjs",
      "require": "./dist/styles/index.js"
    },
    "./cn": {
      "types": "./dist/utils/cn.d.ts",
      "import": "./dist/utils/cn.mjs",
      "require": "./dist/utils/cn.js"
    }
  },
  "files": [
    "dist/**/*",
    "README.md"
  ],
  "scripts": {
    "build": "tsup",
    "clean": "rm -rf dist",
    "dev": "tsup --watch",
    "prepublishOnly": "pnpm run clean && pnpm run build",
    "type-check": "tsc --noEmit",
    "lint": "eslint src/**/*.ts src/**/*.tsx",
    "lint:fix": "eslint src/**/*.ts src/**/*.tsx --fix",
    "format": "prettier --write \"src/**/*.ts\" \"src/**/*.tsx\" \"src/**/*.css\"",
    "format:check": "prettier --check \"src/**/*.ts\" \"src/**/*.tsx\" \"src/**/*.css\""
  },
  "keywords": [
    "ui",
    "components",
    "react",
    "design-system",
    "enterprise",
    "ecommerce",
    "vubon",
    "bangladesh",
    "tailwind",
    "accessible",
    "responsive",
    "dark-mode",
    "themes"
  ],
  "author": "Vubon E-commerce",
  "license": "UNLICENSED",
  "private": true,
  "engines": {
    "node": ">=18.0.0",
    "pnpm": ">=8.0.0"
  },
  "packageManager": "pnpm@8.15.0",
  "peerDependencies": {
    "react": "^18.0.0",
    "react-dom": "^18.0.0"
  },
  "dependencies": {
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.0.0",
    "framer-motion": "^10.16.0",
    "tailwind-merge": "^2.0.0"
  },
  "devDependencies": {
    "@types/react": "^18.0.0",
    "@types/react-dom": "^18.0.0",
    "@typescript-eslint/eslint-plugin": "^6.0.0",
    "@typescript-eslint/parser": "^6.0.0",
    "autoprefixer": "^10.4.0",
    "eslint": "^8.0.0",
    "eslint-plugin-react": "^7.33.0",
    "eslint-plugin-react-hooks": "^4.6.0",
    "husky": "^8.0.0",
    "lint-staged": "^15.0.0",
    "postcss": "^8.4.0",
    "prettier": "^3.0.0",
    "react": "^18.0.0",
    "react-dom": "^18.0.0",
    "tailwindcss": "^3.4.0",
    "tsup": "^8.0.0",
    "typescript": "^5.0.0"
  },
  "sideEffects": [
    "**/*.css"
  ],
  "publishConfig": {
    "access": "restricted",
    "registry": "https://npm.pkg.github.com/",
    "tag": "latest"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/vubon/shared-ui.git"
  },
  "bugs": {
    "url": "https://github.com/vubon/shared-ui/issues"
  },
  "homepage": "https://vubon.com.bd",
  "typesVersions": {
    "*": {
      "components": [
        "./dist/components/index.d.ts"
      ],
      "components/ui": [
        "./dist/components/ui/index.d.ts"
      ],
      "components/forms": [
        "./dist/components/forms/index.d.ts"
      ],
      "components/layout": [
        "./dist/components/layout/index.d.ts"
      ],
      "hooks": [
        "./dist/hooks/index.d.ts"
      ],
      "styles": [
        "./dist/styles/index.d.ts"
      ],
      "cn": [
        "./dist/utils/cn.d.ts"
      ]
    }
  }
}
