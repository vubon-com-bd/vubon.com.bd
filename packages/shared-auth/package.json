{
  "name": "@vubon/shared-auth",
  "version": "1.0.0",
  "description": "Enterprise authentication orchestration layer for vubon.com.bd ecommerce ecosystem - Bangladesh's #1 E-commerce",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    },
    "./client": {
      "types": "./dist/client/index.d.ts",
      "import": "./dist/client/index.mjs",
      "require": "./dist/client/index.js"
    },
    "./react": {
      "types": "./dist/react/index.d.ts",
      "import": "./dist/react/index.mjs",
      "require": "./dist/react/index.js"
    },
    "./guards": {
      "types": "./dist/guards/index.d.ts",
      "import": "./dist/guards/index.mjs",
      "require": "./dist/guards/index.js"
    },
    "./auth-client": {
      "types": "./dist/client/auth.client.d.ts",
      "import": "./dist/client/auth.client.mjs",
      "require": "./dist/client/auth.client.js"
    },
    "./token-storage": {
      "types": "./dist/client/token-storage.d.ts",
      "import": "./dist/client/token-storage.mjs",
      "require": "./dist/client/token-storage.js"
    },
    "./token-refresh": {
      "types": "./dist/client/token-refresh.d.ts",
      "import": "./dist/client/token-refresh.mjs",
      "require": "./dist/client/token-refresh.js"
    },
    "./session-manager": {
      "types": "./dist/client/session-manager.d.ts",
      "import": "./dist/client/session-manager.mjs",
      "require": "./dist/client/session-manager.js"
    },
    "./device-fingerprint": {
      "types": "./dist/client/device-fingerprint.client.d.ts",
      "import": "./dist/client/device-fingerprint.client.mjs",
      "require": "./dist/client/device-fingerprint.client.js"
    },
    "./mfa-client": {
      "types": "./dist/client/mfa.client.d.ts",
      "import": "./dist/client/mfa.client.mjs",
      "require": "./dist/client/mfa.client.js"
    },
    "./account-lock-client": {
      "types": "./dist/client/account-lock.client.d.ts",
      "import": "./dist/client/account-lock.client.mjs",
      "require": "./dist/client/account-lock.client.js"
    },
    "./verification-client": {
      "types": "./dist/client/verification.client.d.ts",
      "import": "./dist/client/verification.client.mjs",
      "require": "./dist/client/verification.client.js"
    },
    "./social-client": {
      "types": "./dist/client/social.client.d.ts",
      "import": "./dist/client/social.client.mjs",
      "require": "./dist/client/social.client.js"
    },
    "./use-auth": {
      "types": "./dist/react/useAuth.d.ts",
      "import": "./dist/react/useAuth.mjs",
      "require": "./dist/react/useAuth.js"
    },
    "./use-permission": {
      "types": "./dist/react/usePermission.d.ts",
      "import": "./dist/react/usePermission.mjs",
      "require": "./dist/react/usePermission.js"
    },
    "./use-session": {
      "types": "./dist/react/useSession.d.ts",
      "import": "./dist/react/useSession.mjs",
      "require": "./dist/react/useSession.js"
    },
    "./use-social-auth": {
      "types": "./dist/react/useSocialAuth.d.ts",
      "import": "./dist/react/useSocialAuth.mjs",
      "require": "./dist/react/useSocialAuth.js"
    },
    "./use-mfa": {
      "types": "./dist/react/useMFA.d.ts",
      "import": "./dist/react/useMFA.mjs",
      "require": "./dist/react/useMFA.js"
    },
    "./use-account-lock": {
      "types": "./dist/react/useAccountLock.d.ts",
      "import": "./dist/react/useAccountLock.mjs",
      "require": "./dist/react/useAccountLock.js"
    },
    "./use-verification": {
      "types": "./dist/react/useVerification.d.ts",
      "import": "./dist/react/useVerification.mjs",
      "require": "./dist/react/useVerification.js"
    },
    "./use-device-trust": {
      "types": "./dist/react/useDeviceTrust.d.ts",
      "import": "./dist/react/useDeviceTrust.mjs",
      "require": "./dist/react/useDeviceTrust.js"
    },
    "./auth-context": {
      "types": "./dist/react/AuthContext.d.ts",
      "import": "./dist/react/AuthContext.mjs",
      "require": "./dist/react/AuthContext.js"
    },
    "./auth-provider": {
      "types": "./dist/react/AuthProvider.d.ts",
      "import": "./dist/react/AuthProvider.mjs",
      "require": "./dist/react/AuthProvider.js"
    },
    "./require-auth": {
      "types": "./dist/guards/RequireAuth.d.ts",
      "import": "./dist/guards/RequireAuth.mjs",
      "require": "./dist/guards/RequireAuth.js"
    },
    "./public-route": {
      "types": "./dist/guards/PublicRoute.d.ts",
      "import": "./dist/guards/PublicRoute.mjs",
      "require": "./dist/guards/PublicRoute.js"
    },
    "./require-role": {
      "types": "./dist/guards/RequireRole.d.ts",
      "import": "./dist/guards/RequireRole.mjs",
      "require": "./dist/guards/RequireRole.js"
    },
    "./require-permission": {
      "types": "./dist/guards/RequirePermission.d.ts",
      "import": "./dist/guards/RequirePermission.mjs",
      "require": "./dist/guards/RequirePermission.js"
    },
    "./require-mfa": {
      "types": "./dist/guards/RequireMFA.d.ts",
      "import": "./dist/guards/RequireMFA.mjs",
      "require": "./dist/guards/RequireMFA.js"
    },
    "./require-device-trust": {
      "types": "./dist/guards/RequireDeviceTrust.d.ts",
      "import": "./dist/guards/RequireDeviceTrust.mjs",
      "require": "./dist/guards/RequireDeviceTrust.js"
    }
  },
  "files": [
    "dist/**/*",
    "README.md"
  ],
  "scripts": {
    "build": "tsup",
    "build:tsc": "tsc",
    "clean": "rm -rf dist",
    "dev": "tsup --watch",
    "prepublishOnly": "npm run clean && npm run build",
    "test": "vitest",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage",
    "type-check": "tsc --noEmit",
    "lint": "eslint src/**/*.ts src/**/*.tsx",
    "lint:fix": "eslint src/**/*.ts src/**/*.tsx --fix",
    "format": "prettier --write \"src/**/*.ts\" \"src/**/*.tsx\"",
    "format:check": "prettier --check \"src/**/*.ts\" \"src/**/*.tsx\""
  },
  "keywords": [
    "auth",
    "authentication",
    "react",
    "session",
    "token",
    "enterprise",
    "ecommerce",
    "vubon",
    "bangladesh",
    "jwt",
    "mfa",
    "2fa",
    "oauth",
    "social-login",
    "bkash",
    "nagad",
    "rocket",
    "whatsapp",
    "role-based",
    "permission",
    "route-guard"
  ],
  "author": "Vubon E-commerce",
  "license": "UNLICENSED",
  "private": true,
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  },
  "dependencies": {
    "jose": "^5.0.0",
    "js-cookie": "^3.0.5"
  },
  "peerDependencies": {
    "react": "^18.0.0",
    "react-dom": "^18.0.0",
    "@vubon/shared-api": "workspace:*",
    "@vubon/shared-types": "workspace:*",
    "@vubon/auth-constants": "workspace:*",
    "@vubon/auth-schemas": "workspace:*",
    "@vubon/shared-utils": "workspace:*",
    "@vubon/shared-config": "workspace:*"
  },
  "devDependencies": {
    "@types/js-cookie": "^3.0.6",
    "@types/react": "^18.0.0",
    "@types/react-dom": "^18.0.0",
    "@typescript-eslint/eslint-plugin": "^6.0.0",
    "@typescript-eslint/parser": "^6.0.0",
    "eslint": "^8.0.0",
    "eslint-plugin-react": "^7.33.0",
    "eslint-plugin-react-hooks": "^4.6.0",
    "prettier": "^3.0.0",
    "react": "^18.0.0",
    "react-dom": "^18.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.0.0",
    "vitest": "^1.0.0"
  },
  "sideEffects": false,
  "publishConfig": {
    "access": "restricted",
    "registry": "https://npm.pkg.github.com/"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/vubon/shared-auth.git"
  },
  "bugs": {
    "url": "https://github.com/vubon/shared-auth/issues"
  },
  "homepage": "https://vubon.com.bd"
}
