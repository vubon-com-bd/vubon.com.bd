{
  "name": "@vubon/shared-api",
  "version": "1.0.0",
  "description": "Enterprise API client layer for vubon.com.bd authentication service - Bangladesh's #1 E-commerce",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    },
    "./client": {
      "types": "./dist/client/index.d.ts",
      "import": "./dist/client/index.mjs",
      "require": "./dist/client/index.js"
    },
    "./endpoints": {
      "types": "./dist/endpoints/index.d.ts",
      "import": "./dist/endpoints/index.mjs",
      "require": "./dist/endpoints/index.js"
    },
    "./auth": {
      "types": "./dist/endpoints/auth.endpoints.d.ts",
      "import": "./dist/endpoints/auth.endpoints.mjs",
      "require": "./dist/endpoints/auth.endpoints.js"
    },
    "./social": {
      "types": "./dist/endpoints/social.endpoints.d.ts",
      "import": "./dist/endpoints/social.endpoints.mjs",
      "require": "./dist/endpoints/social.endpoints.js"
    },
    "./user": {
      "types": "./dist/endpoints/user.endpoints.d.ts",
      "import": "./dist/endpoints/user.endpoints.mjs",
      "require": "./dist/endpoints/user.endpoints.js"
    },
    "./role": {
      "types": "./dist/endpoints/role.endpoints.d.ts",
      "import": "./dist/endpoints/role.endpoints.mjs",
      "require": "./dist/endpoints/role.endpoints.js"
    },
    "./permission": {
      "types": "./dist/endpoints/permission.endpoints.d.ts",
      "import": "./dist/endpoints/permission.endpoints.mjs",
      "require": "./dist/endpoints/permission.endpoints.js"
    },
    "./session": {
      "types": "./dist/endpoints/session.endpoints.d.ts",
      "import": "./dist/endpoints/session.endpoints.mjs",
      "require": "./dist/endpoints/session.endpoints.js"
    },
    "./mfa": {
      "types": "./dist/endpoints/mfa.endpoints.d.ts",
      "import": "./dist/endpoints/mfa.endpoints.mjs",
      "require": "./dist/endpoints/mfa.endpoints.js"
    },
    "./device": {
      "types": "./dist/endpoints/device.endpoints.d.ts",
      "import": "./dist/endpoints/device.endpoints.mjs",
      "require": "./dist/endpoints/device.endpoints.js"
    },
    "./verification": {
      "types": "./dist/endpoints/verification.endpoints.d.ts",
      "import": "./dist/endpoints/verification.endpoints.mjs",
      "require": "./dist/endpoints/verification.endpoints.js"
    },
    "./account-lock": {
      "types": "./dist/endpoints/account-lock.endpoints.d.ts",
      "import": "./dist/endpoints/account-lock.endpoints.mjs",
      "require": "./dist/endpoints/account-lock.endpoints.js"
    },
    "./axios": {
      "types": "./dist/client/axios.client.d.ts",
      "import": "./dist/client/axios.client.mjs",
      "require": "./dist/client/axios.client.js"
    },
    "./fetch": {
      "types": "./dist/client/fetch.client.d.ts",
      "import": "./dist/client/fetch.client.mjs",
      "require": "./dist/client/fetch.client.js"
    },
    "./interceptors": {
      "types": "./dist/client/interceptors.d.ts",
      "import": "./dist/client/interceptors.mjs",
      "require": "./dist/client/interceptors.js"
    },
    "./rate-limit": {
      "types": "./dist/client/rate-limit.client.d.ts",
      "import": "./dist/client/rate-limit.client.mjs",
      "require": "./dist/client/rate-limit.client.js"
    },
    "./retry": {
      "types": "./dist/client/retry.client.d.ts",
      "import": "./dist/client/retry.client.mjs",
      "require": "./dist/client/retry.client.js"
    }
  },
  "files": [
    "dist/**/*",
    "README.md"
  ],
  "scripts": {
    "build": "tsup",
    "build:tsc": "tsc",
    "clean": "rm -rf dist",
    "dev": "tsup --watch",
    "prepublishOnly": "npm run clean && npm run build",
    "test": "vitest",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage",
    "type-check": "tsc --noEmit",
    "lint": "eslint src/**/*.ts",
    "lint:fix": "eslint src/**/*.ts --fix",
    "format": "prettier --write \"src/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\""
  },
  "keywords": [
    "api",
    "client",
    "auth",
    "axios",
    "endpoints",
    "enterprise",
    "ecommerce",
    "vubon",
    "bangladesh",
    "jwt",
    "oauth",
    "mfa",
    "session",
    "rate-limit",
    "retry",
    "interceptors",
    "fetch",
    "typescript"
  ],
  "author": "Vubon E-commerce",
  "license": "UNLICENSED",
  "private": true,
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  },
  "dependencies": {
    "axios": "^1.6.0",
    "zod": "^3.22.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@typescript-eslint/eslint-plugin": "^6.0.0",
    "@typescript-eslint/parser": "^6.0.0",
    "eslint": "^8.0.0",
    "prettier": "^3.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.0.0",
    "vitest": "^1.0.0"
  },
  "peerDependencies": {
    "@vubon/auth-constants": "workspace:*",
    "@vubon/shared-types": "workspace:*",
    "@vubon/auth-schemas": "workspace:*",
    "@vubon/shared-utils": "workspace:*",
    "@vubon/shared-config": "workspace:*"
  },
  "sideEffects": false,
  "publishConfig": {
    "access": "restricted",
    "registry": "https://npm.pkg.github.com/"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/vubon/shared-api.git"
  },
  "bugs": {
    "url": "https://github.com/vubon/shared-api/issues"
  },
  "homepage": "https://vubon.com.bd"
}
