{
  "name": "@vubon/shared-hooks",
  "version": "1.0.0",
  "description": "Enterprise React hooks layer for authentication orchestration - Bangladesh's #1 E-commerce",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    },
    "./auth": {
      "types": "./dist/auth/index.d.ts",
      "import": "./dist/auth/index.mjs",
      "require": "./dist/auth/index.js"
    },
    "./user": {
      "types": "./dist/user/index.d.ts",
      "import": "./dist/user/index.mjs",
      "require": "./dist/user/index.js"
    },
    "./session": {
      "types": "./dist/session/index.d.ts",
      "import": "./dist/session/index.mjs",
      "require": "./dist/session/index.js"
    },
    "./mfa": {
      "types": "./dist/mfa/index.d.ts",
      "import": "./dist/mfa/index.mjs",
      "require": "./dist/mfa/index.js"
    },
    "./device": {
      "types": "./dist/device/index.d.ts",
      "import": "./dist/device/index.mjs",
      "require": "./dist/device/index.js"
    },
    "./verification": {
      "types": "./dist/verification/index.d.ts",
      "import": "./dist/verification/index.mjs",
      "require": "./dist/verification/index.js"
    },
    "./use-login": {
      "types": "./dist/auth/useLogin.d.ts",
      "import": "./dist/auth/useLogin.mjs",
      "require": "./dist/auth/useLogin.js"
    },
    "./use-register": {
      "types": "./dist/auth/useRegister.d.ts",
      "import": "./dist/auth/useRegister.mjs",
      "require": "./dist/auth/useRegister.js"
    },
    "./use-logout": {
      "types": "./dist/auth/useLogout.d.ts",
      "import": "./dist/auth/useLogout.mjs",
      "require": "./dist/auth/useLogout.js"
    },
    "./use-user": {
      "types": "./dist/user/useUser.d.ts",
      "import": "./dist/user/useUser.mjs",
      "require": "./dist/user/useUser.js"
    },
    "./use-sessions": {
      "types": "./dist/session/useSessions.d.ts",
      "import": "./dist/session/useSessions.mjs",
      "require": "./dist/session/useSessions.js"
    },
    "./use-mfa": {
      "types": "./dist/mfa/useMFA.d.ts",
      "import": "./dist/mfa/useMFA.mjs",
      "require": "./dist/mfa/useMFA.js"
    },
    "./use-devices": {
      "types": "./dist/device/useDevices.d.ts",
      "import": "./dist/device/useDevices.mjs",
      "require": "./dist/device/useDevices.js"
    }
  },
  "files": [
    "dist/**/*",
    "README.md"
  ],
  "scripts": {
    "build": "tsup",
    "build:tsc": "tsc",
    "clean": "rm -rf dist",
    "dev": "tsup --watch",
    "prepublishOnly": "npm run clean && npm run build",
    "test": "vitest",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage",
    "type-check": "tsc --noEmit",
    "lint": "eslint src/**/*.ts src/**/*.tsx",
    "lint:fix": "eslint src/**/*.ts src/**/*.tsx --fix",
    "format": "prettier --write \"src/**/*.ts\" \"src/**/*.tsx\"",
    "format:check": "prettier --check \"src/**/*.ts\" \"src/**/*.tsx\""
  },
  "keywords": [
    "react",
    "hooks",
    "auth",
    "authentication",
    "tanstack-query",
    "enterprise",
    "ecommerce",
    "vubon",
    "bangladesh",
    "login",
    "register",
    "mfa",
    "session",
    "device",
    "verification",
    "password-reset",
    "social-login",
    "bkash",
    "nagad",
    "rocket",
    "whatsapp"
  ],
  "author": "Vubon E-commerce",
  "license": "UNLICENSED",
  "private": true,
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  },
  "peerDependencies": {
    "react": "^18.0.0",
    "react-dom": "^18.0.0",
    "@tanstack/react-query": "^5.0.0",
    "@vubon/shared-api": "workspace:*",
    "@vubon/shared-auth": "workspace:*",
    "@vubon/shared-types": "workspace:*",
    "@vubon/auth-schemas": "workspace:*",
    "@vubon/auth-constants": "workspace:*",
    "@vubon/shared-utils": "workspace:*",
    "@vubon/shared-config": "workspace:*"
  },
  "devDependencies": {
    "@tanstack/react-query": "^5.0.0",
    "@types/react": "^18.0.0",
    "@types/react-dom": "^18.0.0",
    "@typescript-eslint/eslint-plugin": "^6.0.0",
    "@typescript-eslint/parser": "^6.0.0",
    "eslint": "^8.0.0",
    "eslint-plugin-react": "^7.33.0",
    "eslint-plugin-react-hooks": "^4.6.0",
    "prettier": "^3.0.0",
    "react": "^18.0.0",
    "react-dom": "^18.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.0.0",
    "vitest": "^1.0.0"
  },
  "sideEffects": false,
  "publishConfig": {
    "access": "restricted",
    "registry": "https://npm.pkg.github.com/"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/vubon/shared-hooks.git"
  },
  "bugs": {
    "url": "https://github.com/vubon/shared-hooks/issues"
  },
  "homepage": "https://vubon.com.bd"
}
