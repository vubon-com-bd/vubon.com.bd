# ==============================================================================
# Vubon Monorepo - Local Environment Variables (DO NOT COMMIT TO GIT)
# ==============================================================================

# ------------------------------------------------------------------------------
# App Environment
# ------------------------------------------------------------------------------
NODE_ENV=development
PORT=5000

# ------------------------------------------------------------------------------
# Database - Prisma / PostgreSQL Connection
# ------------------------------------------------------------------------------
# ফরম্যাট: postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=SCHEMA
DATABASE_URL="postgresql://postgres:postgres_password@localhost:5432/vubon_db?schema=public"

# ------------------------------------------------------------------------------
# Authentication / JWT Secrets
# ------------------------------------------------------------------------------
# লোকাল ডেভেলপমেন্টের জন্য যেকোনো ৩টি ভিন্ন শক্তিশালী র্যান্ডম টেক্সট দিন
JWT_ACCESS_SECRET="local_super_secret_access_token_key_vubon_2026"
JWT_REFRESH_SECRET="local_super_secret_refresh_token_key_vubon_2026"
JWT_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="7d"

# ------------------------------------------------------------------------------
# Third-Party / External Services (প্রয়োজনীয় এপিআই কি থাকলে এখানে বসবে)
# ------------------------------------------------------------------------------
# SENDGRID_API_KEY="your-local-sendgrid-key"
# STRIPE_SECRET_KEY="your-local-stripe-key"
