# ============================================================
# Application Configuration (Test)
# ============================================================

NODE_ENV=test
APP_PORT=3001
APP_URL=http://localhost:3001
APP_NAME=auth-service-test
LOG_LEVEL=error

# ============================================================
# Database Configuration (Test - Isolated)
# ============================================================

DATABASE_URL=postgresql://postgres:postgres@localhost:5432/auth_test_db
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=auth_test_db
DB_SSL=false
DB_POOL_SIZE=2
DB_CONNECTION_TIMEOUT=10000
DB_IDLE_TIMEOUT=10000
DB_LOGGING_ENABLED=false

# ============================================================
# Redis Configuration (Test - Separate DB)
# ============================================================

REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=1
REDIS_KEY_PREFIX=auth:test:

# Redis TTL (Short for tests)
REDIS_SESSION_TTL=60
REDIS_OTP_TTL=30
REDIS_USER_CACHE_TTL=30
REDIS_MFA_SESSION_TTL=30
REDIS_RATE_LIMIT_TTL=60

# ============================================================
# JWT Configuration (Test - Short expiration)
# ============================================================

JWT_SECRET=test-secret-key-do-not-use-in-production
JWT_ACCESS_EXPIRATION=30s
JWT_REFRESH_EXPIRATION=1h
JWT_RESET_EXPIRATION=30s
JWT_VERIFICATION_EXPIRATION=1h
JWT_ALGORITHM=HS256
JWT_ISSUER=vubon.com.bd
JWT_AUDIENCE=vubon-api

# ============================================================
# Email Configuration (Test - Mock)
# ============================================================

MAIL_HOST=localhost
MAIL_PORT=1025
MAIL_SECURE=false
MAIL_USER=test@test.com
MAIL_PASSWORD=
MAIL_FROM=noreply@vubon.com.bd
MAIL_FROM_NAME=Vubon Test

# Skip actual email sending in tests
SKIP_EMAIL_IN_TEST=true
MAIL_QUEUE_ENABLED=false

# Mock email service
MOCK_EMAIL_SERVICE_URL=http://localhost:8025

# ============================================================
# SMS Configuration (Test - Mock)
# ============================================================

MOCK_SMS_IN_TEST=true
TWILIO_ACCOUNT_SID=test_sid
TWILIO_AUTH_TOKEN=test_token
TWILIO_PHONE_NUMBER=+1234567890
MOCK_SMS_SERVICE_URL=http://localhost:8026

# ============================================================
# OAuth Configuration (Test - Mock credentials)
# ============================================================

# Google
GOOGLE_CLIENT_ID=test-google-client-id
GOOGLE_CLIENT_SECRET=test-google-secret
GOOGLE_CALLBACK_URL=http://localhost:3001/api/v1/auth/google/callback

# Facebook
FACEBOOK_CLIENT_ID=test-facebook-id
FACEBOOK_CLIENT_SECRET=test-facebook-secret
FACEBOOK_CALLBACK_URL=http://localhost:3001/api/v1/auth/facebook/callback

# GitHub
GITHUB_CLIENT_ID=test-github-id
GITHUB_CLIENT_SECRET=test-github-secret
GITHUB_CALLBACK_URL=http://localhost:3001/api/v1/auth/github/callback

# Apple
APPLE_CLIENT_ID=test-apple-id
APPLE_CLIENT_SECRET=test-apple-secret
APPLE_CALLBACK_URL=http://localhost:3001/api/v1/auth/apple/callback
APPLE_TEAM_ID=test-team-id
APPLE_KEY_ID=test-key-id
APPLE_PRIVATE_KEY=-----BEGIN PRIVATE KEY-----

# ============================================================
# Rate Limiting (Test - Disabled or very high limits)
# ============================================================

RATE_LIMIT_ENABLED=false
RATE_LIMIT_TTL=60
RATE_LIMIT_MAX=10000
RATE_LIMIT_LOGIN_MAX=1000
RATE_LIMIT_LOGIN_WINDOW=60
RATE_LIMIT_REGISTER_MAX=1000
RATE_LIMIT_REGISTER_WINDOW=60
RATE_LIMIT_API_MAX=10000
RATE_LIMIT_ADMIN_MAX=10000

# ============================================================
# MFA Configuration (Test)
# ============================================================

MFA_TOTP_ISSUER=VubonTest
MFA_TOTP_WINDOW=2
MFA_BACKUP_CODE_COUNT=5
MFA_VERIFICATION_ATTEMPTS=5
MFA_LOCKOUT_DURATION_MINUTES=1

# ============================================================
# Session Configuration (Test)
# ============================================================

SESSION_IDLE_TIMEOUT=300
SESSION_ABSOLUTE_TIMEOUT=3600
SESSION_REMEMBER_ME_DAYS=1
SESSION_MAX_CONCURRENT=10

# ============================================================
# Queue Configuration (Test - Disabled)
# ============================================================

QUEUE_REDIS_DB=2
QUEUE_EMAIL_MAX_ATTEMPTS=1
QUEUE_SMS_MAX_ATTEMPTS=1
QUEUE_DEFAULT_DELAY_MS=0
QUEUE_ENABLED=false

# ============================================================
# Security Configuration (Test)
# ============================================================

BCRYPT_ROUNDS=4 # Lower for faster tests
CORS_ORIGIN=*
HELMET_ENABLED=false
COMPRESSION_ENABLED=false

# ============================================================
# Feature Flags (Test)
# ============================================================

FEATURE_MFA_ENABLED=true
FEATURE_SOCIAL_LOGIN_ENABLED=true
FEATURE_EMAIL_VERIFICATION_ENABLED=true
FEATURE_SMS_VERIFICATION_ENABLED=true

# ============================================================
# Test Specific Settings
# ============================================================

# Test timeouts
TEST_TIMEOUT=30000
TEST_RETRIES=0
TEST_CACHE_DURATION=0

# Mock services
MOCK_DATABASE=false
MOCK_REDIS=false
MOCK_JWT=false

# Test database cleanup
TEST_DB_CLEANUP_ENABLED=true
TEST_DB_RETAIN_DATA=false

# Performance test settings
PERFORMANCE_TEST_ENABLED=false
LOAD_TEST_USERS=100

# ============================================================
# Debugging (Test)
# ============================================================

DEBUG=
DEBUG_COLORS=true

# ============================================================
# Swagger Documentation (Test - Disabled)
# ============================================================

SWAGGER_ENABLED=false

# ============================================================
# Health Check
# ============================================================

HEALTH_CHECK_PATH=/health
