# ============================================================
# Application Configuration (Test)
# ============================================================

NODE_ENV=test
APP_PORT=3001
APP_URL=http://localhost:3001
APP_NAME=auth-service-test
LOG_LEVEL=error

# ============================================================
# Database Configuration (Test - Isolated)
# ============================================================

DATABASE_URL=postgresql://postgres:postgres@localhost:5432/auth_test_db
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=auth_test_db
DB_SSL=false
DB_POOL_SIZE=2
DB_CONNECTION_TIMEOUT=10000
DB_IDLE_TIMEOUT=10000
DB_LOGGING_ENABLED=false
DB_MAX_RETRIES=1

# ============================================================
# Redis Configuration (Test - Simplified, No Sentinel)
# ============================================================

REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=1
REDIS_KEY_PREFIX=auth:test:
REDIS_SENTINEL_ENABLED=false  # ✅ Fixed: No Sentinel in test

# Redis TTL (Short for tests)
REDIS_SESSION_TTL=60
REDIS_OTP_TTL=30
REDIS_USER_CACHE_TTL=30
REDIS_MFA_SESSION_TTL=30
REDIS_RATE_LIMIT_TTL=60
REDIS_BLACKLIST_TTL=300

# ============================================================
# JWT Configuration (Test - Short expiration for quick tests)
# ============================================================

JWT_SECRET=test-secret-key-do-not-use-in-production
JWT_ACCESS_EXPIRATION=30s
JWT_REFRESH_EXPIRATION=1h
JWT_RESET_EXPIRATION=30s
JWT_VERIFICATION_EXPIRATION=1h
JWT_MFA_EXPIRATION=30s
JWT_MAGIC_LINK_EXPIRATION=30s
JWT_ALGORITHM=HS256
JWT_ISSUER=vubon.com.bd
JWT_AUDIENCE=vubon-api
JWT_CLOCK_TOLERANCE=10

# ============================================================
# Email Configuration (Test - Mock)
# ============================================================

MAIL_HOST=localhost
MAIL_PORT=1025
MAIL_SECURE=false
MAIL_USER=test@test.com
MAIL_PASSWORD=
MAIL_FROM=noreply@vubon.com.bd
MAIL_FROM_NAME=Vubon Test
MAIL_REPLY_TO=test@vubon.com.bd

# Skip actual email sending in tests
SKIP_EMAIL_IN_TEST=true
MAIL_QUEUE_ENABLED=false

# Mock email service
MOCK_EMAIL_SERVICE_URL=http://localhost:8025

# ============================================================
# SMS Configuration (Test - Mock)
# ============================================================

MOCK_SMS_IN_TEST=true
TWILIO_ACCOUNT_SID=test_sid
TWILIO_AUTH_TOKEN=test_token
TWILIO_PHONE_NUMBER=+1234567890
MOCK_SMS_SERVICE_URL=http://localhost:8026

# SMS rate limits disabled for test
SMS_RATE_LIMIT_PER_HOUR=1000
SMS_RATE_LIMIT_PER_DAY=10000

# ============================================================
# WhatsApp Configuration (Test - Mock, Bangladesh specific)
# ============================================================

WHATSAPP_BUSINESS_PHONE_ID=test_phone_id
WHATSAPP_ACCESS_TOKEN=test_access_token
WHATSAPP_BUSINESS_ACCOUNT_ID=test_business_account_id
WHATSAPP_VERIFY_TOKEN=test_verify_token
MOCK_WHATSAPP_IN_TEST=true

# ============================================================
# OAuth Configuration (Test - Mock credentials)
# ============================================================

# Google
GOOGLE_CLIENT_ID=test-google-client-id
GOOGLE_CLIENT_SECRET=test-google-secret
GOOGLE_CALLBACK_URL=http://localhost:3001/api/v1/auth/google/callback
GOOGLE_SCOPES=email,profile

# Facebook
FACEBOOK_CLIENT_ID=test-facebook-id
FACEBOOK_CLIENT_SECRET=test-facebook-secret
FACEBOOK_CALLBACK_URL=http://localhost:3001/api/v1/auth/facebook/callback
FACEBOOK_API_VERSION=v18.0
FACEBOOK_SCOPES=email,public_profile

# GitHub
GITHUB_CLIENT_ID=test-github-id
GITHUB_CLIENT_SECRET=test-github-secret
GITHUB_CALLBACK_URL=http://localhost:3001/api/v1/auth/github/callback
GITHUB_SCOPES=read:user,user:email

# Apple
APPLE_CLIENT_ID=test-apple-id
APPLE_CLIENT_SECRET=test-apple-secret
APPLE_CALLBACK_URL=http://localhost:3001/api/v1/auth/apple/callback
APPLE_TEAM_ID=test-team-id
APPLE_KEY_ID=test-key-id
APPLE_PRIVATE_KEY=-----BEGIN PRIVATE KEY-----

# LinkedIn
LINKEDIN_CLIENT_ID=test-linkedin-id
LINKEDIN_CLIENT_SECRET=test-linkedin-secret
LINKEDIN_CALLBACK_URL=http://localhost:3001/api/v1/auth/linkedin/callback
LINKEDIN_API_VERSION=v2
LINKEDIN_SCOPES=openid,profile,email

# ============================================================
# Rate Limiting (Test - Disabled for performance)
# ============================================================

RATE_LIMIT_ENABLED=false
RATE_LIMIT_TTL=60
RATE_LIMIT_MAX=10000
RATE_LIMIT_LOGIN_MAX=1000
RATE_LIMIT_LOGIN_WINDOW=60
RATE_LIMIT_REGISTER_MAX=1000
RATE_LIMIT_REGISTER_WINDOW=60
RATE_LIMIT_FORGOT_PASSWORD_MAX=1000
RATE_LIMIT_FORGOT_PASSWORD_WINDOW=60
RATE_LIMIT_API_MAX=10000
RATE_LIMIT_API_WINDOW=60
RATE_LIMIT_ADMIN_MAX=10000
RATE_LIMIT_ADMIN_WINDOW=60
RATE_LIMIT_MFA_MAX=1000
RATE_LIMIT_MFA_WINDOW=60

# Bulk rate limiting disabled in test
RATE_LIMIT_BULK_MAX_ATTEMPTS=10000
RATE_LIMIT_BULK_BLOCK_DURATION_MINUTES=0

# ============================================================
# MFA Configuration (Test)
# ============================================================

MFA_TOTP_ISSUER=VubonTest
MFA_TOTP_ALGORITHM=SHA1
MFA_TOTP_DIGITS=6
MFA_TOTP_PERIOD=30
MFA_TOTP_WINDOW=2
MFA_BACKUP_CODE_COUNT=5
MFA_BACKUP_CODE_LENGTH=8
MFA_BACKUP_CODE_FORMAT=plain
MFA_VERIFICATION_ATTEMPTS=5
MFA_LOCKOUT_DURATION_MINUTES=1
MFA_VERIFICATION_SESSION_TTL_SECONDS=60

# ============================================================
# Session Configuration (Test)
# ============================================================

SESSION_IDLE_TIMEOUT=300
SESSION_ABSOLUTE_TIMEOUT=3600
SESSION_REMEMBER_ME_DAYS=1
SESSION_MAX_CONCURRENT=10
SESSION_BIND_IP=false
SESSION_BIND_USER_AGENT=false
SESSION_ENCRYPT_COOKIE=false

# ============================================================
# Queue Configuration (Test - Disabled for faster tests)
# ============================================================

QUEUE_REDIS_DB=2
QUEUE_EMAIL_MAX_ATTEMPTS=1
QUEUE_SMS_MAX_ATTEMPTS=1
QUEUE_WHATSAPP_MAX_ATTEMPTS=1
QUEUE_DEFAULT_DELAY_MS=0
QUEUE_ENABLED=false
QUEUE_DLQ_ENABLED=false

# ============================================================
# Security Configuration (Test - Relaxed)
# ============================================================

BCRYPT_ROUNDS=4                              # ✅ Faster for tests
ARGON2_ITERATIONS=1
CORS_ORIGIN=*
HELMET_ENABLED=false
COMPRESSION_ENABLED=false
CSRF_PROTECTION_ENABLED=false
TRUST_PROXY=false

# ============================================================
# Password Policy (Test)
# ============================================================

PASSWORD_MIN_LENGTH=4
PASSWORD_MAX_LENGTH=128
PASSWORD_REQUIRE_UPPERCASE=false
PASSWORD_REQUIRE_LOWERCASE=false
PASSWORD_REQUIRE_NUMBERS=false
PASSWORD_REQUIRE_SPECIAL=false
PASSWORD_HISTORY_COUNT=2
PASSWORD_EXPIRY_DAYS=999

# ============================================================
# Feature Flags (Test - Enable all for coverage)
# ============================================================

FEATURE_MFA_ENABLED=true
FEATURE_SOCIAL_LOGIN_ENABLED=true
FEATURE_EMAIL_VERIFICATION_ENABLED=true
FEATURE_SMS_VERIFICATION_ENABLED=true
FEATURE_WHATSAPP_VERIFICATION_ENABLED=true
FEATURE_DEVICE_FINGERPRINT_ENABLED=false
FEATURE_OFFLINE_MFA_ENABLED=false
FEATURE_PASSWORD_EXPIRY_ENABLED=false
FEATURE_ACCOUNT_LOCKOUT_ENABLED=true
FEATURE_BULK_OPERATIONS_ENABLED=false
FEATURE_ADMIN_API_ENABLED=true
FEATURE_DOCS_ENABLED=false

# ============================================================
# Test Specific Settings
# ============================================================

TEST_TIMEOUT=30000
TEST_RETRIES=0
TEST_CACHE_DURATION=0

# Mock services
MOCK_DATABASE=false
MOCK_REDIS=false
MOCK_JWT=false

# Test database cleanup
TEST_DB_CLEANUP_ENABLED=true
TEST_DB_RETAIN_DATA=false
TEST_DB_CLEANUP_BETWEEN_SUITES=true

# Performance test settings
PERFORMANCE_TEST_ENABLED=false
LOAD_TEST_USERS=100

# ============================================================
# Cache Management (Test)
# ============================================================

CACHE_DEFAULT_TTL=30
CACHE_ADAPTIVE_TTL_ENABLED=false
CACHE_COMPRESSION_ENABLED=false
CACHE_WARMUP_ENABLED=false

# ============================================================
# Monitoring & Observability (Test - Disabled)
# ============================================================

HEALTH_CHECK_PATH=/health
SENTRY_DSN=
OTEL_ENABLED=false
PROMETHEUS_METRICS_ENABLED=false

# ============================================================
# Geographic Configuration (Bangladesh specific - Test)
# ============================================================

DEFAULT_TIMEZONE=Asia/Dhaka
DEFAULT_LOCALE=en
DEFAULT_COUNTRY=BD
CURRENCY=BDT
GEO_IP_ENABLED=false
DISTRICT_DATA_ENABLED=false
UPAZILA_DATA_ENABLED=false

# ============================================================
# Debugging (Test)
# ============================================================

DEBUG=
DEBUG_COLORS=true

# ============================================================
# Swagger Documentation (Test - Disabled)
# ============================================================

SWAGGER_ENABLED=false
