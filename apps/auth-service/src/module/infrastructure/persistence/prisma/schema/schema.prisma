// ============================================================
// Generator
// ============================================================

generator client {
  provider = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  extensions = [pgcrypto]
}

// ============================================================
// Enums
// ============================================================

enum UserStatus {
  ACTIVE
  INACTIVE
  LOCKED
  SUSPENDED
  DELETED
}

enum UserRole {
  USER
  ADMIN
  MODERATOR
  SUPER_ADMIN
}

enum SessionStatus {
  ACTIVE
  REVOKED
  EXPIRED
  IDLE_EXPIRED
}

enum RefreshTokenStatus {
  ACTIVE
  REVOKED
  USED
  EXPIRED
  COMPROMISED
}

enum MFAType {
  TOTP
  SMS
  EMAIL
  WEBAUTHN
}

enum MFAStatus {
  ENABLED
  DISABLED
  PENDING_VERIFICATION
  LOCKED
  RECOVERY_MODE
}

enum SocialProvider {
  GOOGLE
  FACEBOOK
  GITHUB
  APPLE
  TWITTER
  LINKEDIN
  WHATSAPP
  IMO
  TELEGRAM
  BKASH
  NAGAD
  ROCKET
}

enum EmailVerificationStatus {
  PENDING
  VERIFIED
  EXPIRED
  REVOKED
}

enum PasswordResetStatus {
  PENDING
  USED
  EXPIRED
  CANCELLED
}

enum AccountLockReason {
  FAILED_LOGIN_ATTEMPTS
  SUSPICIOUS_ACTIVITY
  ADMIN_ACTION
  POLICY_VIOLATION
  BRUTE_FORCE_DETECTED
  SIM_SWAP_DETECTED
}

enum LoginResult {
  SUCCESS
  FAILED_PASSWORD
  ACCOUNT_LOCKED
  ACCOUNT_INACTIVE
  MFA_REQUIRED
  MFA_FAILED
  SUSPICIOUS
  RATE_LIMITED
  IP_BLOCKED
}

enum DeviceType {
  MOBILE
  TABLET
  DESKTOP
  TV
  BOT
  WEARABLE
  CONSOLE
  UNKNOWN
}

// ============================================================
// Models
// ============================================================

model User {
  id                  String              @id @default(cuid())
  email               String              @unique
  password            String
  fullName            String
  phone               String?
  role                UserRole            @default(USER)
  status              UserStatus          @default(ACTIVE)
  isEmailVerified     Boolean             @default(false)
  isPhoneVerified     Boolean             @default(false)
  mfaEnabled          Boolean             @default(false)
  lastLoginAt         DateTime?
  deletedAt           DateTime?
  createdAt           DateTime            @default(now())
  updatedAt           DateTime            @updatedAt
  version             Int                 @default(1)
  metadata            Json?               // For future extensibility

  // Relations
  sessions            Session[]
  refreshTokens       RefreshToken[]
  mfa                 MFA?
  socialAccounts      SocialAccount[]
  emailVerifications  EmailVerification[]
  passwordResets      PasswordReset[]
  accountLock         AccountLock?
  loginAttempts       LoginAttempt[]
  devices             Device[]

  // Indexes
  @@index([email])
  @@index([status])
  @@index([role])
  @@index([createdAt])
  @@index([deletedAt])
  @@index([status, role])
}

model Session {
  id              String         @id @default(cuid())
  userId          String
  token           String         @unique
  ipAddress       String
  userAgent       String
  deviceId        String
  status          SessionStatus  @default(ACTIVE)
  expiresAt       DateTime
  lastActivityAt  DateTime       @default(now())
  location        String?        // City/Country from IP
  sessionName     String?        // User-friendly name
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  version         Int            @default(1)
  metadata        Json?

  user            User           @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([token])
  @@index([deviceId])
  @@index([status])
  @@index([expiresAt])
  @@index([userId, status])
  @@index([lastActivityAt])
}

model RefreshToken {
  id              String             @id @default(cuid())
  userId          String
  token           String             @unique
  status          RefreshTokenStatus @default(ACTIVE)
  expiresAt       DateTime
  revokedAt       DateTime?
  usedAt          DateTime?
  family          String
  previousTokenId String?
  rotationCount   Int                @default(0)
  compromisedAt   DateTime?
  compromisedReason String?
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt
  version         Int                @default(1)
  metadata        Json?

  user            User               @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([token])
  @@index([family])
  @@index([status])
  @@index([expiresAt])
  @@index([userId, status])
  @@index([family, status])
}

model MFA {
  id                String       @id @default(cuid())
  userId            String       @unique
  type              MFAType
  secret            String       // Encrypted secret
  status            MFAStatus    @default(PENDING_VERIFICATION)
  backupCodes       String[]     // Hashed backup codes
  verifiedAt        DateTime?
  lastUsedAt        DateTime?
  failedAttempts    Int          @default(0)
  lockedUntil       DateTime?
  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @updatedAt
  version           Int          @default(1)
  metadata          Json?

  user              User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, status])
}

model SocialAccount {
  id              String         @id @default(cuid())
  userId          String
  provider        SocialProvider
  providerUserId  String
  providerEmail   String
  providerName    String?
  isLinked        Boolean        @default(true)
  linkedAt        DateTime       @default(now())
  unlinkedAt      DateTime?
  lastSyncAt      DateTime?
  profilePicture  String?
  profileUrl      String?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  version         Int            @default(1)
  metadata        Json?

  user            User           @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerUserId])
  @@index([userId])
  @@index([provider, providerUserId])
  @@index([isLinked])
  @@index([provider])
}

model EmailVerification {
  id                String                  @id @default(cuid())
  userId            String
  email             String
  code              String                  // Hashed verification code
  status            EmailVerificationStatus @default(PENDING)
  expiresAt         DateTime
  verifiedAt        DateTime?
  resendCount       Int                     @default(0)
  lastResentAt      DateTime?
  createdAt         DateTime                @default(now())
  updatedAt         DateTime                @updatedAt
  version           Int                     @default(1)
  metadata          Json?

  user              User                    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([code])
  @@index([status])
  @@index([expiresAt])
  @@index([userId, status])
}

model PasswordReset {
  id                String                 @id @default(cuid())
  userId            String
  token             String                 @unique
  status            PasswordResetStatus    @default(PENDING)
  expiresAt         DateTime
  usedAt            DateTime?
  cancelledAt       DateTime?
  requestCount      Int                    @default(1)
  lastRequestAt     DateTime?
  ipAddress         String?
  userAgent         String?
  deviceId          String?
  createdAt         DateTime               @default(now())
  updatedAt         DateTime               @updatedAt
  version           Int                    @default(1)
  metadata          Json?

  user              User                   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([token])
  @@index([status])
  @@index([expiresAt])
  @@index([userId, status])
}

model AccountLock {
  id                String            @id @default(cuid())
  userId            String            @unique
  reason            AccountLockReason
  lockedAt          DateTime          @default(now())
  unlockedAt        DateTime?
  failureCount      Int               @default(0)
  lockLevel         Int               @default(0)
  lockedUntil       DateTime?
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt
  version           Int               @default(1)
  metadata          Json?

  user              User              @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([lockedUntil])
  @@index([isLocked])
}

model LoginAttempt {
  id                String          @id @default(cuid())
  userId            String?
  email             String
  ipAddress         String
  userAgent         String
  deviceId          String
  result            LoginResult
  attemptedAt       DateTime        @default(now())
  riskScore         Int             @default(0)
  failureReason     String?
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt
  version           Int             @default(1)
  metadata          Json?

  user              User?           @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([email])
  @@index([ipAddress])
  @@index([deviceId])
  @@index([result])
  @@index([attemptedAt])
  @@index([userId, attemptedAt])
  @@index([email, attemptedAt])
  @@index([ipAddress, attemptedAt])
}

model Device {
  id                String        @id @default(cuid())
  userId            String
  deviceId          String        @unique
  deviceType        DeviceType
  userAgent         String
  isTrusted         Boolean       @default(false)
  lastUsedAt        DateTime      @default(now())
  trustedAt         DateTime?
  fingerprint       String?       // Device fingerprint hash
  deviceName        String?       // User-friendly name
  location          String?       // Last known location
  usageCount        Int           @default(0)
  lastIPAddress     String?
  status            String        @default("ACTIVE")
  suspendedAt       DateTime?
  suspendedReason   String?
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt
  version           Int           @default(1)
  metadata          Json?

  user              User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([deviceId])
  @@index([isTrusted])
  @@index([lastUsedAt])
  @@index([userId, isTrusted])
  @@index([deviceType])
}
