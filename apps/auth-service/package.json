{
  "name": "@vubon/auth-service",
  "version": "1.0.0",
  "description": "Authentication microservice for vubon.com.bd - Bangladesh's #1 E-commerce",
  "author": "Vubon Team",
  "license": "UNLICENSED",
  "private": true,
  "engines": {
    "node": ">=20.0.0",
    "npm": ">=10.0.0"
  },
  "packageManager": "npm@10.0.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/vubon/auth-service.git"
  },
  "bugs": {
    "url": "https://github.com/vubon/auth-service/issues"
  },
  "homepage": "https://github.com/vubon/auth-service#readme",
  "scripts": {
    "build": "nest build",
    "start": "nest start",
    "start:dev": "nest start --watch",
    "start:debug": "nest start --debug --watch",
    "start:prod": "node dist/main",
    "type-check": "tsc --noEmit",
    "type-check:watch": "tsc --noEmit --watch",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:deploy": "prisma migrate deploy",
    "prisma:reset": "prisma migrate reset",
    "prisma:seed": "ts-node prisma/seed.ts",
    "prisma:studio": "prisma studio",
    "prisma:format": "prisma format",
    "format": "prettier --write \"src/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\"",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\"",
    "lint:fix": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "lint:check": "eslint \"{src,apps,libs,test}/**/*.ts\"",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand",
    "test:e2e": "jest --config ./test/jest-e2e.json",
    "docker:build": "docker build -t auth-service .",
    "docker:up": "docker-compose up -d",
    "docker:down": "docker-compose down",
    "docker:logs": "docker-compose logs -f",
    "clean": "rm -rf dist node_modules",
    "prebuild": "rimraf dist",
    "postinstall": "npm run prisma:generate"
  },
  "dependencies": {
    "@nestjs/common": "^10.4.22",
    "@nestjs/config": "^4.0.4",
    "@nestjs/core": "^10.4.22",
    "@nestjs/cqrs": "^11.0.3",
    "@nestjs/event-emitter": "^3.1.0",
    "@nestjs/jwt": "^10.0.0",
    "@nestjs/passport": "^10.0.0",
    "@nestjs/platform-express": "^10.4.22",
    "@nestjs/schedule": "^6.1.3",
    "@nestjs/swagger": "^7.4.0",
    "@nestjs/terminus": "^11.1.1",
    "@nestjs/throttler": "^6.5.0",
    "@prisma/client": "^5.0.0",
    "@vubon/shared-config": "file:../../packages/shared-config",
    "@vubon/shared-constants": "file:../../packages/shared-constants",
    "@vubon/shared-schemas": "file:../../packages/shared-schemas",
    "@vubon/shared-types": "file:../../packages/shared-types",
    "@vubon/shared-utils": "file:../../packages/shared-utils",
    "argon2": "^0.44.0",
    "bull": "^1.1.3",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.0",
    "compression": "^1.7.4",
    "cookie-parser": "^1.4.6",
    "helmet": "^7.0.0",
    "ioredis": "^5.3.0",
    "nodemailer": "^9.0.0",
    "passport": "^0.7.0",
    "passport-apple": "^2.0.0",
    "passport-facebook": "^3.0.0",
    "passport-github2": "^0.1.12",
    "passport-google-oauth20": "^2.0.0",
    "passport-jwt": "^4.0.1",
    "passport-local": "^1.0.0",
    "reflect-metadata": "^0.1.13",
    "rxjs": "^7.8.0",
    "speakeasy": "^2.0.0",
    "twilio": "^4.0.0",
    "uuid": "^14.0.0"
  },
  "devDependencies": {
  "@nestjs/cli": "^10.0.0",
  "@nestjs/schematics": "^11.1.0",
  "@nestjs/testing": "^11.1.26",
  "@types/bull": "^4.10.0",
  "@types/compression": "^1.7.5",
  "@types/cookie-parser": "^1.4.6",
  "@types/express": "^4.17.17",
  "@types/jest": "^29.5.0",
  "@types/node": "^20.0.0",
  "@types/nodemailer": "^6.4.0",
  "@types/passport-jwt": "^4.0.0",
  "@types/passport-local": "^1.0.0",
  "@types/speakeasy": "^2.0.0",
  "@types/supertest": "^6.0.0",
  "@types/uuid": "^9.0.0",
  "@typescript-eslint/eslint-plugin": "^6.0.0",
  "@typescript-eslint/parser": "^6.0.0",
  "eslint": "^8.42.0",
  "eslint-config-prettier": "^9.0.0",
  "eslint-plugin-prettier": "^5.0.0",
  "jest": "^29.5.0",
  "prettier": "^3.0.0",
  "@trivago/prettier-plugin-sort-imports": "^5.2.2",
  "prisma": "^5.0.0",
  "rimraf": "^5.0.0",
  "source-map-support": "^0.5.21",
  "supertest": "^6.3.0",
  "ts-jest": "^29.1.0",
  "ts-loader": "^9.4.3",
  "ts-node": "^10.9.0",
  "tsconfig-paths": "^4.2.0",
  "typescript": "^5.1.3"
  }
}
