# ============================================================
# Application Configuration
# ============================================================

# Environment (development, production, test, staging)
NODE_ENV=development

# Application port
APP_PORT=3000

# Application URL (for CORS, callbacks)
APP_URL=http://localhost:3000
FRONTEND_URL=http://localhost:3000

# API URL (internal)
API_URL=http://localhost:3000

# Application name
APP_NAME=vubon-auth-service

# Log level (debug, info, warn, error)
LOG_LEVEL=info

# ============================================================
# Security & Rate Limiting Configuration
# ============================================================

# CORS configuration (add all production domains)
CORS_ORIGIN=http://localhost:3000,http://localhost:3001,https://vubon.com.bd,https://www.vubon.com.bd,https://api.vubon.com.bd,https://admin.vubon.com.bd,https://seller.vubon.com.bd
CORS_CREDENTIALS=true
CORS_MAX_AGE=86400

# Helmet security headers
HELMET_ENABLED=true
HELMET_HSTS_ENABLED=true
HELMET_HSTS_MAX_AGE=31536000               # 1 year

# Compression
COMPRESSION_ENABLED=true
COMPRESSION_LEVEL=6
COMPRESSION_THRESHOLD=1024                 # Compress responses > 1KB

# CSRF protection
CSRF_PROTECTION_ENABLED=true
CSRF_COOKIE_NAME=csrf-token
CSRF_COOKIE_SECURE=true

# Rate limiting store (memory, redis)
RATE_LIMITER_STORE=redis
RATE_LIMITER_KEY_PREFIX=ratelimit:

# Global rate limits
RATE_LIMIT_TTL=60
RATE_LIMIT_MAX=100

# Per-endpoint rate limits
RATE_LIMIT_LOGIN_MAX=5
RATE_LIMIT_LOGIN_WINDOW=900                # 15 minutes
RATE_LIMIT_REGISTER_MAX=3
RATE_LIMIT_REGISTER_WINDOW=3600            # 1 hour
RATE_LIMIT_FORGOT_PASSWORD_MAX=3
RATE_LIMIT_FORGOT_PASSWORD_WINDOW=3600
RATE_LIMIT_API_MAX=200
RATE_LIMIT_API_WINDOW=60                   # 1 minute
RATE_LIMIT_ADMIN_MAX=500
RATE_LIMIT_ADMIN_WINDOW=60
RATE_LIMIT_MFA_MAX=5
RATE_LIMIT_MFA_WINDOW=900                  # 15 minutes

# Bulk rate limiting (IP-based)
RATE_LIMIT_BULK_MAX_ATTEMPTS=100
RATE_LIMIT_BULK_BLOCK_DURATION_MINUTES=5
RATE_LIMIT_BULK_WINDOW_MS=60000

# ============================================================
# Circuit Breaker Configuration (Resilience)
# ============================================================

CIRCUIT_BREAKER_ENABLED=true
CIRCUIT_BREAKER_TIMEOUT_MS=10000
CIRCUIT_BREAKER_ERROR_THRESHOLD_PERCENTAGE=50
CIRCUIT_BREAKER_RESET_TIMEOUT_MS=30000
CIRCUIT_BREAKER_ROLLING_COUNT_TIMEOUT_MS=10000
CIRCUIT_BREAKER_ROLLING_COUNT_BUCKETS=10

# ============================================================
# Health Check Configuration
# ============================================================

HEALTH_CHECK_ENABLED=true
HEALTH_CHECK_PATH=/health
HEALTH_CHECK_READINESS_PATH=/ready
HEALTH_CHECK_LIVENESS_PATH=/live
HEALTH_CHECK_STARTUP_PATH=/startup
HEALTH_CHECK_TIMEOUT_MS=5000
HEALTH_CHECK_INTERVAL_MS=30000

# ============================================================
# Database Configuration (PostgreSQL)
# ============================================================

# Primary connection string (Prisma)
DATABASE_URL=postgresql://postgres:password@localhost:5432/auth_db?schema=public&connection_limit=10&pool_timeout=30

# Individual connection parameters (fallback / alternative)
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=your_password_here
DB_NAME=auth_db
DB_SSL=false
DB_POOL_SIZE=10
DB_CONNECTION_TIMEOUT=30000
DB_IDLE_TIMEOUT=60000
DB_LOGGING_ENABLED=false
DB_QUERY_LOG_ENABLED=false
DB_QUERY_LOG_SLOW_THRESHOLD_MS=100

# ============================================================
# Redis Configuration
# ============================================================

# Single node configuration
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_KEY_PREFIX=auth:
REDIS_TLS=false

# Redis Cluster Configuration (Production)
REDIS_CLUSTER_ENABLED=false
REDIS_CLUSTER_NODES=redis-node1:6379,redis-node2:6379,redis-node3:6379
REDIS_CLUSTER_MAX_REDIRECTS=3

# Redis Sentinel Configuration (Production)
REDIS_SENTINEL_ENABLED=false
REDIS_SENTINEL_MASTER_NAME=mymaster
REDIS_SENTINEL_NODES=sentinel1:26379,sentinel2:26379,sentinel3:26379

# Redis connection settings
REDIS_CONNECT_TIMEOUT=10000
REDIS_MAX_RETRIES=3
REDIS_RETRY_DELAY_MS=100

# Redis TTL configurations (seconds)
REDIS_SESSION_TTL=3600           # 1 hour
REDIS_OTP_TTL=300                # 5 minutes
REDIS_USER_CACHE_TTL=600         # 10 minutes
REDIS_MFA_SESSION_TTL=300        # 5 minutes
REDIS_RATE_LIMIT_TTL=60          # 1 minute
REDIS_BLACKLIST_TTL=86400        # 24 hours

# ============================================================
# Queue Configuration (BullMQ)
# ============================================================

QUEUE_REDIS_DB=1
QUEUE_EMAIL_MAX_ATTEMPTS=3
QUEUE_SMS_MAX_ATTEMPTS=3
QUEUE_WHATSAPP_MAX_ATTEMPTS=3
QUEUE_DEFAULT_DELAY_MS=5000
QUEUE_CONCURRENCY_EMAIL=5
QUEUE_CONCURRENCY_SMS=10
QUEUE_CONCURRENCY_WHATSAPP=5
QUEUE_CONCURRENCY_WEBHOOK=20

# Queue dead letter queue
QUEUE_DLQ_ENABLED=true
QUEUE_DLQ_MAX_RETRIES=3
QUEUE_DLQ_RETRY_DELAY_MS=60000

# ============================================================
# JWT Configuration
# ============================================================

# Required: JWT secret (min 32 characters, use strong random)
# Generate: openssl rand -base64 32
JWT_SECRET=ch4nge_th1s_t0_4_5tr0ng_r4nd0m_5tr1ng_w1th_32+_ch4r5_!@#

# JWT expiration times
JWT_ACCESS_EXPIRATION=15m
JWT_REFRESH_EXPIRATION=7d
JWT_RESET_EXPIRATION=1h
JWT_VERIFICATION_EXPIRATION=24h
JWT_MFA_EXPIRATION=5m
JWT_MAGIC_LINK_EXPIRATION=5m

# JWT algorithm (HS256, RS256, ES256, PS256)
JWT_ALGORITHM=HS256

# JWT issuer and audience
JWT_ISSUER=vubon.com.bd
JWT_AUDIENCE=vubon-api

# JWT clock tolerance (seconds)
JWT_CLOCK_TOLERANCE=30

# ============================================================
# Email Configuration (SMTP)
# ============================================================

MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_SECURE=false
MAIL_USER=noreply@vubon.com.bd
MAIL_PASSWORD=your-smtp-password
MAIL_FROM=noreply@vubon.com.bd
MAIL_FROM_NAME=Vubon E-commerce

# Email templates
EMAIL_TEMPLATE_DIR=./templates/email
EMAIL_VERIFICATION_TEMPLATE=verification.hbs
EMAIL_PASSWORD_RESET_TEMPLATE=password-reset.hbs
EMAIL_WELCOME_TEMPLATE=welcome.hbs
EMAIL_MFA_TEMPLATE=mfa-code.hbs

# Email queue settings
MAIL_QUEUE_ENABLED=true
MAIL_RETRY_ATTEMPTS=3
MAIL_RETRY_DELAY_MS=5000
MAIL_QUEUE_CONCURRENCY=5

# Skip email sending in development
SKIP_EMAIL_IN_DEV=false

# ============================================================
# SMS Configuration (Twilio)
# ============================================================

TWILIO_ACCOUNT_SID=your_account_sid
TWILIO_AUTH_TOKEN=your_auth_token
TWILIO_PHONE_NUMBER=+1234567890

# SMS templates
SMS_OTP_TEMPLATE="Your verification code is: {{code}}"
SMS_PASSWORD_RESET_TEMPLATE="Use this code to reset your password: {{code}}"

# SMS rate limiting
SMS_RATE_LIMIT_PER_HOUR=10
SMS_RATE_LIMIT_PER_DAY=50
SMS_QUEUE_CONCURRENCY=10

# SMS retry configuration
SMS_RETRY_ATTEMPTS=3
SMS_RETRY_DELAY_MS=2000

# Mock SMS in development (set to true to skip actual sending)
MOCK_SMS_IN_DEV=false
MOCK_SMS_IN_TEST=true

# Skip WhatsApp in development
SKIP_WHATSAPP_IN_DEV=true
SKIP_RATE_LIMITING_IN_DEV=false

# ============================================================
# WhatsApp Configuration (Bangladesh specific)
# ============================================================

WHATSAPP_BUSINESS_PHONE_ID=your_phone_id
WHATSAPP_ACCESS_TOKEN=your_access_token
WHATSAPP_BUSINESS_ACCOUNT_ID=your_business_account_id
WHATSAPP_VERIFY_TOKEN=your_verify_token

# WhatsApp templates
WHATSAPP_OTP_TEMPLATE=otp_verification
WHATSAPP_PASSWORD_RESET_TEMPLATE=password_reset
WHATSAPP_MFA_TEMPLATE=mfa_code

# WhatsApp rate limiting
WHATSAPP_RATE_LIMIT_PER_HOUR=20
WHATSAPP_QUEUE_CONCURRENCY=5

# ============================================================
# OAuth Configuration - Google
# ============================================================

GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_CALLBACK_URL=http://localhost:3000/auth/google/callback

# Google OAuth scopes (comma-separated)
GOOGLE_SCOPES=email,profile

# ============================================================
# OAuth Configuration - Facebook
# ============================================================

FACEBOOK_CLIENT_ID=your_facebook_client_id
FACEBOOK_CLIENT_SECRET=your_facebook_client_secret
FACEBOOK_CALLBACK_URL=http://localhost:3000/auth/facebook/callback
FACEBOOK_API_VERSION=v18.0

# Facebook OAuth scopes
FACEBOOK_SCOPES=email,public_profile

# ============================================================
# OAuth Configuration - GitHub
# ============================================================

GITHUB_CLIENT_ID=your_github_client_id
GITHUB_CLIENT_SECRET=your_github_client_secret
GITHUB_CALLBACK_URL=http://localhost:3000/auth/github/callback

# GitHub OAuth scopes
GITHUB_SCOPES=read:user,user:email

# ============================================================
# OAuth Configuration - Apple
# ============================================================

APPLE_CLIENT_ID=your_apple_client_id
APPLE_TEAM_ID=your_team_id
APPLE_KEY_ID=your_key_id
APPLE_PRIVATE_KEY=-----BEGIN PRIVATE KEY-----
APPLE_CALLBACK_URL=http://localhost:3000/auth/apple/callback

# ============================================================
# OAuth Configuration - LinkedIn
# ============================================================

LINKEDIN_CLIENT_ID=your_linkedin_client_id
LINKEDIN_CLIENT_SECRET=your_linkedin_client_secret
LINKEDIN_CALLBACK_URL=http://localhost:3000/auth/linkedin/callback
LINKEDIN_API_VERSION=v2

# LinkedIn OAuth scopes
LINKEDIN_SCOPES=openid,profile,email

# ============================================================
# MFA (Multi-Factor Authentication) Configuration
# ============================================================

MFA_TOTP_ISSUER=vubon.com.bd
MFA_TOTP_ALGORITHM=SHA1
MFA_TOTP_DIGITS=6
MFA_TOTP_PERIOD=30
MFA_TOTP_WINDOW=1

# Backup codes configuration
MFA_BACKUP_CODE_COUNT=10
MFA_BACKUP_CODE_LENGTH=8
MFA_BACKUP_CODE_FORMAT=alphanumeric
MFA_BACKUP_CODE_SALT_ROUNDS=12
MFA_BACKUP_CODE_STORE_HASHED=true
MFA_BACKUP_CODE_MAX_ATTEMPTS=5

# MFA verification settings
MFA_VERIFICATION_ATTEMPTS=3
MFA_LOCKOUT_DURATION_MINUTES=15
MFA_VERIFICATION_SESSION_TTL_SECONDS=300   # 5 minutes

# MFA recovery options
MFA_RECOVERY_EMAIL_ENABLED=true
MFA_RECOVERY_PHONE_ENABLED=true
MFA_RECOVERY_BACKUP_CODE_ENABLED=true

# Offline MFA (Bangladesh specific - for poor network areas)
MFA_OFFLINE_ENABLED=true
MFA_OFFLINE_CODE_COUNT=20
MFA_OFFLINE_CODE_EXPIRY_DAYS=90

# ============================================================
# Session Configuration
# ============================================================

SESSION_IDLE_TIMEOUT=1800                   # 30 minutes
SESSION_ABSOLUTE_TIMEOUT=86400              # 24 hours
SESSION_REMEMBER_ME_DAYS=30
SESSION_MAX_CONCURRENT=5
SESSION_MAX_DEVICES=10

# Session security
SESSION_BIND_IP=false
SESSION_BIND_USER_AGENT=true
SESSION_BIND_DEVICE_ID=true
SESSION_ENCRYPT_COOKIE=true

# Trusted device settings
TRUSTED_DEVICE_ENABLED=true
TRUSTED_DEVICE_TTL_DAYS=30
TRUSTED_DEVICE_MAX_PER_USER=10
TRUSTED_DEVICE_ROTATION_ENABLED=true

# ============================================================
# Security & Password Configuration
# ============================================================

# Password policy
PASSWORD_MIN_LENGTH=8
PASSWORD_MAX_LENGTH=128
PASSWORD_REQUIRE_UPPERCASE=true
PASSWORD_REQUIRE_LOWERCASE=true
PASSWORD_REQUIRE_NUMBERS=true
PASSWORD_REQUIRE_SPECIAL=true
PASSWORD_HISTORY_COUNT=5
PASSWORD_EXPIRY_DAYS=90                   # Bangladesh Bank guideline

# Password hashing
BCRYPT_ROUNDS=10
ARGON2_MEMORY=65536                       # 64 MB
ARGON2_PARALLELISM=4
ARGON2_ITERATIONS=3

# ============================================================
# Device Fingerprinting (Bangladesh specific)
# ============================================================

DEVICE_FINGERPRINT_ENABLED=true
DEVICE_FINGERPRINT_SALT=your-fingerprint-salt-change-me-in-production
DEVICE_FINGERPRINT_HEADERS=user-agent,accept-language,accept-encoding
DEVICE_FINGERPRINT_VERSION=1

# Mobile network detection (Bangladesh 2G/3G/4G/5G)
MOBILE_NETWORK_DETECTION_ENABLED=true
BANGLADESH_MOBILE_OPERATORS=gp,robi,banglalink,teletalk
MOBILE_NETWORK_TYPES=2g,3g,4g,5g,wifi,unknown

# Device trust scoring
DEVICE_TRUST_SCORING_ENABLED=true
DEVICE_TRUST_MIN_SCORE=30
DEVICE_TRUST_MAX_SCORE=100

# ============================================================
# Cache Management
# ============================================================

CACHE_DEFAULT_TTL=3600                    # 1 hour
CACHE_ADAPTIVE_TTL_ENABLED=true
CACHE_COMPRESSION_ENABLED=true
CACHE_COMPRESSION_THRESHOLD=2048          # 2KB
CACHE_WARMUP_ENABLED=true

# Multi-tier cache (L1 memory, L2 Redis)
CACHE_MULTI_TIER_ENABLED=false
CACHE_L1_TTL_SECONDS=60                   # 1 minute for L1
CACHE_L1_MAX_ITEMS=10000

# ============================================================
# Feature Flags
# ============================================================

FEATURE_MFA_ENABLED=true
FEATURE_SOCIAL_LOGIN_ENABLED=true
FEATURE_EMAIL_VERIFICATION_ENABLED=true
FEATURE_SMS_VERIFICATION_ENABLED=false
FEATURE_WHATSAPP_VERIFICATION_ENABLED=false
FEATURE_DEVICE_FINGERPRINT_ENABLED=true
FEATURE_OFFLINE_MFA_ENABLED=true
FEATURE_PASSWORD_EXPIRY_ENABLED=true
FEATURE_ACCOUNT_LOCKOUT_ENABLED=true
FEATURE_BULK_OPERATIONS_ENABLED=false
FEATURE_ADMIN_API_ENABLED=true
FEATURE_DOCS_ENABLED=false

# ============================================================
# Monitoring & Observability
# ============================================================

# Sentry error tracking
SENTRY_DSN=https://your-sentry-dsn@sentry.io/project
SENTRY_TRACES_SAMPLE_RATE=0.1
SENTRY_ENABLED=false

# OpenTelemetry tracing
OTEL_ENABLED=false
OTEL_SERVICE_NAME=auth-service
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
OTEL_EXPORTER_OTLP_HEADERS=
OTEL_TRACES_SAMPLER=parentbased_traceidratio
OTEL_TRACES_SAMPLER_ARG=0.1
OTEL_METRICS_EXPORTER=otlp
OTEL_LOGS_EXPORTER=otlp

# Prometheus metrics
METRICS_ENABLED=false
METRICS_PORT=9090
METRICS_PATH=/metrics
METRICS_PREFIX=auth_service_

# ============================================================
# Geographic Configuration (Bangladesh specific)
# ============================================================

DEFAULT_TIMEZONE=Asia/Dhaka
DEFAULT_LOCALE=bn
DEFAULT_COUNTRY=BD
CURRENCY=BDT

# Location-based security
GEO_IP_ENABLED=true
GEO_IP_DATABASE_PATH=./data/GeoLite2-City.mmdb
GEO_IP_UPDATE_INTERVAL_DAYS=30

# District/Upazila data
DISTRICT_DATA_ENABLED=true
UPAZILA_DATA_ENABLED=true

# ============================================================
# Debug Mode
# ============================================================

# Debug mode (enable detailed error messages)
DEBUG_MODE=false

# ============================================================
# Shared Configuration Overrides (from @vubon/shared-constants)
# ============================================================
# Note: These override default values from shared packages
#=============================================================

SHARED_JWT_ACCESS_EXPIRY=15m
SHARED_JWT_REFRESH_EXPIRY=7d
SHARED_MFA_MAX_ATTEMPTS=3
SHARED_MFA_LOCKOUT_DURATION_MINUTES=15
SHARED_PASSWORD_MIN_LENGTH=8
SHARED_PASSWORD_MAX_LENGTH=128
SHARED_PASSWORD_REQUIRE_SPECIAL=true
SHARED_SESSION_IDLE_TIMEOUT_SECONDS=1800
SHARED_SESSION_ABSOLUTE_TIMEOUT_SECONDS=86400
SHARED_RATE_LIMIT_WINDOW_MS=60000
SHARED_RATE_LIMIT_MAX_REQUESTS=100
SHARED_CACHE_DEFAULT_TTL=3600
SHARED_CACHE_KEY_PREFIX=auth:

# ============================================================
# Kubernetes (Optional)
# ============================================================

# Kubernetes liveness/readiness probes paths
K8S_LIVENESS_PATH=/live
K8S_READINESS_PATH=/ready
K8S_STARTUP_PATH=/startup
