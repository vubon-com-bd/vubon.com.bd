{
  "name": "@vubon/workspace",
  "version": "1.0.1",
  "type": "module",
  "private": true,
  "description": "Vubon.com.bd Enterprise Monorepo",
  "license": "UNLICENSED",
  "packageManager": "npm@11.16.0",
  "engines": {
    "node": ">=22.0.0",
    "npm": ">=10.9.0"
  },
  "workspaces": [
    "apps/*",
    "packages/*",
    "packages/auth/*"
  ],
  "scripts": {
    "install:all": "npm install",
    "build": "npm run build --workspaces",
    "build:auth": "npm run build --workspace=@vubon/auth-service",
    "dev": "npm run start:dev --workspaces",
    "lint": "npm run lint --workspaces",
    "lint:fix": "npm run lint:fix --workspaces",
    "format": "npm run format --workspaces",
    "format:check": "npm run format:check --workspaces",
    "type-check": "npm run type-check --workspaces",
    "test": "npm run test --workspaces",
    "test:coverage": "npm run test:cov --workspaces",
    "check": "npm run format:check && npm run lint && npm run type-check && npm test",
    "ci": "npm ci && npm run check",
    "clean": "npm run clean --workspaces && rimraf node_modules",
    "reinstall": "rimraf node_modules package-lock.json && npm install",
    "prisma:generate": "npm run prisma:generate --workspace=@vubon/auth-service"
  },
  "overrides": {
    "typescript": "^5.9.2",
    "eslint": "^9.32.0",
    "prettier": "^3.6.2"
  },
  "devDependencies": {
    "@eslint/js": "^9.32.0",
    "@trivago/prettier-plugin-sort-imports": "^5.2.2",
    "@typescript-eslint/eslint-plugin": "^8.38.0",
    "@typescript-eslint/parser": "^8.38.0",
    "eslint": "^9.32.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-import-resolver-typescript": "^4.4.4",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-jest": "^29.0.1",
    "eslint-plugin-prettier": "^5.5.3",
    "eslint-plugin-security": "^3.0.1",
    "globals": "^16.3.0",
    "prettier": "^3.6.2",
    "prisma": "^6.13.0",
    "rimraf": "^6.0.1",
    "typescript": "^5.9.2",
    "typescript-eslint": "^8.38.0"
  },
  "dependencies": {
    "@prisma/client": "6.19.3"
  }
}
